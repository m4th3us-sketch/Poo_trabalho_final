    /** CT11 — Associar ficha sem exercícios deve lançar FichaSemExercicioException. */
    static void testCT11_AssociarFichaSemExercicio() {
        try {
            Aluno.resetContador(900); FichaTreino.resetContador(200); Exercicio.resetContador(1);
            AlunoRepositorio ar = new AlunoRepositorio(TMP_DIR);
            AlunoService as = new AlunoService(ar);
            Aluno a = as.cadastrar("Gabriel", "999.999.999-99", LocalDate.of(1994, 12, 3), "61010", "g@x.com");
            FichaTreinoService fs = fichaSvc(ar);
            FichaTreino f = fs.cadastrar("Treino B", "Emagrecimento");
            fs.associarAluno(f.getId(), a.getId());
            fail("CT11", "Deveria lançar FichaSemExercicioException");
        } catch (FichaSemExercicioException e) { ok("CT11 — Ficha sem exercício lança exceção"); }
          catch (Exception e) { fail("CT11", "Exceção errada: " + e.getClass().getSimpleName()); }
    }

    /** CT12 — Associar ficha com exercícios deve funcionar corretamente. */
    static void testCT12_AssociarFichaComExercicio() {
        try {
            Aluno.resetContador(1000); FichaTreino.resetContador(300); Exercicio.resetContador(500);
            AlunoRepositorio ar = new AlunoRepositorio(TMP_DIR);
            AlunoService as = new AlunoService(ar);
            Aluno a = as.cadastrar("Helena", "000.000.000-00", LocalDate.of(1991, 6, 18), "61020", "h@x.com");
            FichaTreinoService fs = fichaSvc(ar);
            FichaTreino f = fs.cadastrar("Treino C", "Força");
            fs.adicionarExercicio(f.getId(), "Agachamento", 4, 12);
            FichaTreino associada = fs.associarAluno(f.getId(), a.getId());
            if (associada.getAlunoId() == a.getId()) ok("CT12 — Associar ficha com exercício");
            else fail("CT12", "alunoId não foi atualizado");
        } catch (Exception e) { fail("CT12", e.getMessage()); }
    }

    /** CT13 — Imprimir ficha deve retornar string com nome dos exercícios. */
    static void testCT13_ImprimirFicha() {
        try {
            Aluno.resetContador(1100); FichaTreino.resetContador(400); Exercicio.resetContador(600);
            AlunoRepositorio ar = new AlunoRepositorio(TMP_DIR);
            FichaTreinoService fs = fichaSvc(ar);
            FichaTreino f = fs.cadastrar("Treino D", "Resistência");
            fs.adicionarExercicio(f.getId(), "Esteira", 1, 30);
