        } catch (Exception e) { fail("CT13", e.getMessage()); }
    }

    /** CT14 — Registrar acompanhamento deve persistir observações e evolução. */
    static void testCT14_RegistrarAcompanhamento() {
        try {
            Aluno.resetContador(1200); Acompanhamento.resetContador(1);
            AlunoRepositorio ar = new AlunoRepositorio(TMP_DIR);
            AlunoService as = new AlunoService(ar);
            Aluno a = as.cadastrar("Igor", "121.212.121-21", LocalDate.of(1987, 2, 14), "61030", "i@x.com");
