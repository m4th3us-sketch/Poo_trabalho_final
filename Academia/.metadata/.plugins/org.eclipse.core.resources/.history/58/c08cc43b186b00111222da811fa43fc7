    /** CT15 — Histórico de acompanhamento deve filtrar por aluno corretamente. */
    static void testCT15_HistoricoAcompanhamentoPorAluno() {
        try {
            Aluno.resetContador(1300); Acompanhamento.resetContador(200);
            AlunoRepositorio ar = new AlunoRepositorio(TMP_DIR);
            AlunoService as = new AlunoService(ar);
            Aluno a1 = as.cadastrar("Julia", "131.313.131-31", LocalDate.of(1999, 10, 10), "61040", "j@x.com");
            Aluno a2 = as.cadastrar("Kleber", "141.414.141-41", LocalDate.of(1983, 7, 7), "61050", "k@x.com");
            AcompanhamentoService acs = acSvc(ar);
            acs.registrar(a1.getId(), LocalDate.now(), "Obs A1-1", "Evo A1-1");
            acs.registrar(a1.getId(), LocalDate.now(), "Obs A1-2", "Evo A1-2");
            acs.registrar(a2.getId(), LocalDate.now(), "Obs A2-1", "Evo A2-1");
            List<Acompanhamento> hist = acs.listarPorAluno(a1.getId());
            if (hist.size() == 2) ok("CT15 — Histórico filtrado por aluno");
            else fail("CT15", "Esperava 2 registros, obteve " + hist.size());
        } catch (Exception e) { fail("CT15", e.getMessage()); }
    }

    /** CT16 — Excluir ficha deve também excluir exercícios associados. */
    static void testCT16_ExcluirFichaExcluiExercicios() {
        try {
            Aluno.resetContador(1400); FichaTreino.resetContador(500); Exercicio.resetContador(700);
            AlunoRepositorio ar = new AlunoRepositorio(TMP_DIR);
            FichaTreinoService fs = fichaSvc(ar);
            FichaTreino f = fs.cadastrar("Treino E", "Mobilidade");
            fs.adicionarExercicio(f.getId(), "Alongamento", 3, 30);
            fs.excluir(f.getId());
            try { fs.buscarPorId(f.getId()); fail("CT16", "Ficha deveria ter sido excluída"); }
            catch (EntidadeNaoEncontradaException e) { ok("CT16 — Excluir ficha remove exercícios"); }
        } catch (Exception e) { fail("CT16", e.getMessage()); }
    }

    /** CT17 — Listar pagamentos por aluno deve retornar apenas os do aluno informado. */
    static void testCT17_ListarPagamentosPorAluno() {
        try {
            Aluno.resetContador(1500); Pagamento.resetContador(300);
            AlunoRepositorio ar = new AlunoRepositorio(TMP_DIR);
            AlunoService as = new AlunoService(ar);
            Aluno a = as.cadastrar("Laura", "151.515.151-51", LocalDate.of(1996, 3, 25), "61060", "la@x.com");
            PagamentoService ps = pagSvc(ar);
            ps.registrar(a.getId(), 100.0, LocalDate.now(), "PIX");
            ps.registrar(a.getId(), 200.0, LocalDate.now(), "Cartão");
            List<Pagamento> pags = ps.listarPorAluno(a.getId());
            if (pags.size() == 2) ok("CT17 — Listar pagamentos por aluno");
            else fail("CT17", "Esperava 2 pagamentos, obteve " + pags.size());
        } catch (Exception e) { fail("CT17", e.getMessage()); }
    }

    /** CT18 — Cancelar pagamento deve alterar status para CANCELADO. */
    static void testCT18_CancelarPagamento() {
        try {
            Aluno.resetContador(1600); Pagamento.resetContador(400);
            AlunoRepositorio ar = new AlunoRepositorio(TMP_DIR);
            AlunoService as = new AlunoService(ar);
            Aluno a = as.cadastrar("Marcos", "161.616.161-61", LocalDate.of(1980, 1, 1), "61070", "ma@x.com");
            PagamentoService ps = pagSvc(ar);
            Pagamento p = ps.registrar(a.getId(), 120.0, LocalDate.now(), "Dinheiro");
            ps.cancelar(p.getId());
            Pagamento atualizado = ps.buscarPorId(p.getId());
            if (atualizado.getStatus().equals("CANCELADO")) ok("CT18 — Cancelar pagamento");
            else fail("CT18", "Status não foi alterado para CANCELADO");
        } catch (Exception e) { fail("CT18", e.getMessage()); }
    }
}
