            ps.registrar(a.getId(), 0.0, LocalDate.now(), "Cartão");
            fail("CT09", "Deveria lançar PagamentoInvalidoException");
        } catch (PagamentoInvalidoException e) { ok("CT09 — Valor zero lança exceção"); }
          catch (Exception e) { fail("CT09", "Exceção errada: " + e.getClass().getSimpleName()); }
    }

    /** CT10 — Cadastrar ficha de treino deve retornar ficha com ID válido e ativa. */
    static void testCT10_CadastrarFichaTreino() {
        try {
            Aluno.resetContador(800); FichaTreino.resetContador(1);
            AlunoRepositorio ar = new AlunoRepositorio(TMP_DIR);
            FichaTreinoService fs = fichaSvc(ar);
            FichaTreino f = fs.cadastrar("Treino A", "Hipertrofia");
            if (f.getId() > 0 && f.isAtiva()) ok("CT10 — Cadastrar ficha de treino");
