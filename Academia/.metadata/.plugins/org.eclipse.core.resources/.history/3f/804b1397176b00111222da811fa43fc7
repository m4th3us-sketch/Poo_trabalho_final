package academia.model;

import java.time.LocalDate;
import java.time.format.DateTimeFormatter;

/**
 * Representa um pagamento realizado por um aluno.
 * Implementa {@link Persistivel} para gravação em arquivo.
 *
 * <p>IDs gerados automaticamente via contador estático.</p>
 *
 * @author Sistema Academia
 * @version 1.0
 */
public class Pagamento implements Persistivel {

    /** Contador estático para IDs sequenciais. */
    private static int contadorId = 1;
    private static final DateTimeFormatter FMT = DateTimeFormatter.ofPattern("dd/MM/yyyy");

    private int id;
    /** ID do aluno associado ao pagamento. */
    private int alunoId;
    /** Valor pago. */
    private double valor;
    /** Data em que o pagamento foi realizado. */
    private LocalDate dataPagamento;
    /** Forma de pagamento (PIX, Cartão, Dinheiro...). */
    private String formaPagamento;
    /** Status do pagamento (PAGO, PENDENTE, CANCELADO). */
    private String status;

    /**
     * Construtor completo — para recarga do arquivo.
     *
     * @param id             ID persistido
     * @param alunoId        ID do aluno
     * @param valor          valor do pagamento
     * @param dataPagamento  data do pagamento
     * @param formaPagamento forma de pagamento
     * @param status         status atual
     */
    public Pagamento(int id, int alunoId, double valor, LocalDate dataPagamento,
                     String formaPagamento, String status) {
        this.id = id;
        this.alunoId = alunoId;
        this.valor = valor;
        this.dataPagamento = dataPagamento;
        this.formaPagamento = formaPagamento;
        this.status = status;
        if (id >= contadorId) contadorId = id + 1;
    }

    /**
     * Construtor sem ID — gera ID automático.
     *
     * @param alunoId        ID do aluno
     * @param valor          valor do pagamento
     * @param dataPagamento  data do pagamento
     * @param formaPagamento forma de pagamento
     * @param status         status
     */
    public Pagamento(int alunoId, double valor, LocalDate dataPagamento,
                     String formaPagamento, String status) {
        this(contadorId++, alunoId, valor, dataPagamento, formaPagamento, status);
    }

    /**
     * Serializa o pagamento em linha para arquivo.
     * Formato: {@code id|alunoId|valor|dataPagamento|formaPagamento|status}
     */
    @Override
    public String toFileString() {
        return id + "|" + alunoId + "|" + valor + "|"
                + dataPagamento.format(FMT) + "|" + formaPagamento + "|" + status;
    }

    /**
     * Reconstrói um {@link Pagamento} a partir de linha do arquivo.
     *
     * @param linha linha formatada
     * @return instância de Pagamento
     */
    public static Pagamento fromFileString(String linha) {
        String[] p = linha.split("\\|");
        return new Pagamento(Integer.parseInt(p[0]), Integer.parseInt(p[1]),
                Double.parseDouble(p[2]), LocalDate.parse(p[3], FMT), p[4], p[5]);
    }

    /** Reseta contador. @param valor novo valor */
    public static void resetContador(int valor) { contadorId = valor; }

    @Override public int getId() { return id; }
    public int getAlunoId() { return alunoId; }
    public double getValor() { return valor; }
    public void setValor(double valor) { this.valor = valor; }
    public LocalDate getDataPagamento() { return dataPagamento; }
    public void setDataPagamento(LocalDate dataPagamento) { this.dataPagamento = dataPagamento; }
    public String getFormaPagamento() { return formaPagamento; }
    public void setFormaPagamento(String formaPagamento) { this.formaPagamento = formaPagamento; }
    public String getStatus() { return status; }
    public void setStatus(String status) { this.status = status; }

    @Override
    public String toString() {
        return String.format("[%d] Aluno#%d | R$ %.2f | %s | %s | %s",
                id, alunoId, valor, dataPagamento.format(FMT), formaPagamento, status);
    }
}
